// prisma/schema.prisma
// Database schema untuk WA CS Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────

enum Role {
  USER
  ADMIN
  FINANCE // Akses terbatas ke /admin/finance untuk verifikasi transfer manual.
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String? // null kalau login via Google
  name          String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts                     Account[]
  sessions                     Session[]
  tokenBalance                 TokenBalance?
  tokenTx                      TokenTransaction[]
  waSessions                   WhatsappSession[]
  souls                        Soul[]
  contacts                     Contact[]
  broadcasts                   Broadcast[]
  aiModelAccess                UserModelAccess[]
  manualPayments               ManualPayment[]            @relation("UserManualPayments")
  confirmedPayments            ManualPayment[]            @relation("ConfirmedByUser")
  subscriptions                Subscription[]
  subscriptionNotifications    SubscriptionNotification[]
  approvedSubscriptionInvoices SubscriptionInvoice[]      @relation("ApprovedSubscriptionInvoice")
  // Pointer ke subscription aktif user — denormalisasi supaya middleware
  // & UI tidak perlu join Subscription tiap request. Auto-update via
  // service layer (activate/expire).
  currentSubscriptionId        String?
  currentPlanExpiresAt         DateTime?
  landingPages                 LandingPage[]
  lpImages                     LpImage[]
  lpGenerations                LpGeneration[]
  lpOptimizations              LpOptimization[]
  lpQuota                      UserQuota?
  soulSimulations              SoulSimulation[]
  soulSimulationPresets        SoulSimulationPreset[]
  knowledge                    UserKnowledge[]
  salesFlows                   UserSalesFlow[]
  orderSessions                OrderSession[]
  orders                       UserOrder[]
  products                     Product[]
  userBankAccounts             UserBankAccount[]
  shippingProfile              UserShippingProfile?
  orderForms                   OrderForm[]
  orderTags                    OrderTag[]
  orderViewPreference          UserOrderViewPreference?
  shippingZones                ShippingZone[]
  pixelIntegrations            PixelIntegration[]
  pixelEventLogs               PixelEventLog[]
  // Bank Mutation Auto-Reader (Phase 1, 2026-05-08, BETA) — 1:1, hanya
  // satu integrasi BCA per user POWER untuk MVP.
  bankMutationIntegration      BankMutationIntegration?
  bankMutations                BankMutation[]
  // Follow-Up Order System (2026-05-08) — auto-WA ke customer per event +
  // delay. POWER only, gating di service layer.
  followUpTemplates            FollowUpTemplate[]
  followUpQueueItems           FollowUpQueue[]
  followUpBlacklist            FollowUpBlacklist[]
  // LMS — Phase 1 (2026-05-09). Course = creator-owned, multi-tenant per user.
  courses                      Course[]
  // LMS — Phase 3 (2026-05-09). Plan upgrade LMS via token.
  lmsQuota                     LmsQuota?
  lmsSubscriptions             LmsSubscription[]
  // Content Studio — Phase 1 (2026-05-10). Idea Generator + AI content gen.
  aiGenerationLogs             AiGenerationLog[]
  contentIdeas                 ContentIdea[]
  contentBriefs                ContentBrief[]
  contentPieces                ContentPiece[]
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Token sekali pakai untuk reset password lewat email.
// Selalu konsumsi via flag `used` (jangan dihapus) supaya audit trail tetap ada.
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ─────────────────────────────────────────
// TOKEN SYSTEM
// ─────────────────────────────────────────

model TokenBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  totalPurchased Int      @default(0)
  totalUsed      Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TokenTxType {
  PURCHASE // Beli token
  USAGE // Pakai token (AI reply)
  REFUND // Refund
  BONUS // Bonus dari admin
  ADJUSTMENT // Penyesuaian manual admin
}

model TokenTransaction {
  id          String      @id @default(cuid())
  userId      String
  amount      Int // positif = tambah, negatif = kurang
  type        TokenTxType
  description String?
  reference   String? // payment ID dari Midtrans
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────
// WHATSAPP SESSION
// ─────────────────────────────────────────

enum WaStatus {
  DISCONNECTED
  CONNECTING
  WAITING_QR
  CONNECTED
  PAUSED // Token habis
  ERROR
}

model WhatsappSession {
  id          String   @id @default(cuid())
  userId      String
  phoneNumber String? // diisi setelah connected
  displayName String?
  status      WaStatus @default(DISCONNECTED)
  sessionData String?  @db.Text // Baileys credentials (encrypted JSON)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soul & model yang dipakai sesi ini
  soulId  String?
  modelId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  soul       Soul?       @relation(fields: [soulId], references: [id])
  model      AiModel?    @relation(fields: [modelId], references: [id])
  contacts   Contact[]
  messages   Message[]
  broadcasts Broadcast[]

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────
// SOUL (Kepribadian AI)
// ─────────────────────────────────────────

model Soul {
  id              String   @id @default(cuid())
  userId          String
  name            String // nama soul, misal "Sari CS Toko Baju"
  systemPrompt    String   @db.Text // prompt lengkap yang dikirim ke AI
  personality     String? // ramah, profesional, santai, dll
  businessContext String?  @db.Text // info bisnis: produk, harga, dsb
  language        String   @default("id") // id = Bahasa Indonesia
  replyStyle      String? // singkat, detail, emoji, dll
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  waSessions WhatsappSession[]

  // Pemakaian sebagai agen di Soul Testing Lab.
  sellerSimulations SoulSimulation[] @relation("SimSellerSoul")
  buyerSimulations  SoulSimulation[] @relation("SimBuyerSoul")
}

// ─────────────────────────────────────────
// SOUL SETTINGS — pilihan kepribadian & gaya balas yang di-curate admin.
// User pilih dari sini lewat dropdown SoulBuilder. systemPromptSnippet
// disuntikkan ke system prompt server-side — TIDAK PERNAH dikirim ke client.
// ─────────────────────────────────────────

model SoulPersonality {
  id                  String   @id @default(cuid())
  name                String
  description         String // teks publik yang user lihat di dropdown
  systemPromptSnippet String   @db.Text // RAHASIA — instruksi AI, hanya admin
  isActive            Boolean  @default(true)
  order               Int      @default(0)
  createdAt           DateTime @default(now())

  // Pemakaian sebagai agen di Soul Testing Lab.
  sellerSimulations SoulSimulation[] @relation("SimSellerPersonality")
  buyerSimulations  SoulSimulation[] @relation("SimBuyerPersonality")

  @@index([isActive, order])
}

model SoulStyle {
  id                  String   @id @default(cuid())
  name                String
  description         String // teks publik yang user lihat di dropdown
  systemPromptSnippet String   @db.Text // RAHASIA — instruksi AI, hanya admin
  isActive            Boolean  @default(true)
  order               Int      @default(0)
  createdAt           DateTime @default(now())

  // Pemakaian sebagai agen di Soul Testing Lab.
  sellerSimulations SoulSimulation[] @relation("SimSellerStyle")
  buyerSimulations  SoulSimulation[] @relation("SimBuyerStyle")

  @@index([isActive, order])
}

// ─────────────────────────────────────────
// AI MODEL
// ─────────────────────────────────────────

enum AiProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
}

model AiModel {
  id       String     @id @default(cuid())
  name     String // "Claude Haiku", "GPT-5 Mini"
  provider AiProvider
  modelId  String // "claude-haiku-4-5-20251001"

  // 'AUTO' = costPerMessage di-set otomatis dari PricingSettings (lihat
  // /admin/pricing-settings + tombol Re-calculate di /admin/models).
  // 'MANUAL' = admin override langsung, sistem tidak overwrite saat recalc.
  costMode       String @default("AUTO")
  // Berapa token platform yang dipotong per balasan AI yang sukses.
  // Admin set manual berdasarkan posisi tier model.
  costPerMessage Int    @default(1)

  // Harga aktual provider (USD per 1 juta token). Dipakai untuk transparansi
  // di dashboard admin & untuk hitung margin platform vs cost provider.
  // Default 0 = belum di-set oleh admin (back-compat untuk existing rows).
  inputPricePer1M     Float @default(0)
  outputPricePer1M    Float @default(0)
  // Estimasi rata-rata token per balasan WA (input prompt + history + output).
  // Dipakai untuk hitung biaya per pesan: avgTokensPerMessage / 1_000_000 *
  // (input + output) / 2  → IDR per pesan.
  avgTokensPerMessage Int   @default(500)

  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  waSessions WhatsappSession[]
  userAccess UserModelAccess[]

  // Pemakaian sebagai engine AI di Soul Testing Lab.
  sellerSimulations SoulSimulation[] @relation("SimSellerModel")
  buyerSimulations  SoulSimulation[] @relation("SimBuyerModel")
}

// Model access per user (admin bisa restrict)
model UserModelAccess {
  userId    String
  modelId   String
  grantedAt DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  model AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([userId, modelId])
}

// ─────────────────────────────────────────
// CRM — CONTACT
// ─────────────────────────────────────────

enum PipelineStage {
  NEW // Baru masuk
  PROSPECT // Tertarik
  INTEREST // Sudah diskusi
  NEGOTIATION // Negosiasi harga
  CLOSED_WON // Beli
  CLOSED_LOST // Tidak jadi
}

model Contact {
  id            String        @id @default(cuid())
  userId        String
  waSessionId   String
  phoneNumber   String
  name          String?
  avatar        String?
  tags          String[]      @default([])
  pipelineStage PipelineStage @default(NEW)
  notes         String?       @db.Text
  isBlacklisted Boolean       @default(false)
  // Kalau true, AI tidak balas pesan dari kontak ini (CS manusia ambil alih).
  aiPaused      Boolean       @default(false)
  // Kalau true, percakapan ditandai selesai — tidak muncul di tab default inbox.
  isResolved    Boolean       @default(false)
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Data tambahan (flexible)
  customFields Json?

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  waSession     WhatsappSession @relation(fields: [waSessionId], references: [id])
  messages      Message[]
  orderSessions OrderSession[]
  orders        UserOrder[]

  @@unique([waSessionId, phoneNumber])
  @@index([userId, pipelineStage])
  @@index([userId, lastMessageAt])
}

// ─────────────────────────────────────────
// CRM — MESSAGE
// ─────────────────────────────────────────

enum MessageRole {
  USER // Pesan dari customer WA
  AI // Balasan dari AI
  HUMAN // Legacy: dulu dipakai untuk CS reply via web. Pesan baru pakai AGENT
  // + source. Disimpan supaya pesan lama tetap render.
  AGENT // Balasan dari CS manusia (web atau langsung dari WA HP).
  // Bedakan asalnya lewat field `source`.
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id              String        @id @default(cuid())
  contactId       String
  waSessionId     String
  content         String        @db.Text
  role            MessageRole
  status          MessageStatus @default(SENT)
  tokensUsed      Int? // berapa token platform dipotong (legacy alias dari tokensCharged)
  // ─── Profitability tracking (di-set saat role=AI) ───
  // Token aktual dari response provider (input/output prompt). Null untuk
  // pesan yang dibuat sebelum fitur ini ada.
  apiInputTokens  Int?
  apiOutputTokens Int?
  // Cost provider real dalam IDR (kurs di-snapshot dari PricingSettings saat
  // pesan dibuat). Disimpan supaya dashboard tidak perlu re-hitung.
  apiCostRp       Float?
  // Token platform yang dipotong dari user (snapshot dari model.costPerMessage).
  tokensCharged   Int?
  // Pendapatan platform (IDR) = tokensCharged × pricePerToken (snapshot kurs jual).
  revenueRp       Float?
  // Profit (IDR) = revenueRp - apiCostRp. Bisa negatif (= rugi) → trigger alert.
  profitRp        Float?
  // Asal pesan untuk role AGENT — bedakan CS reply via web vs langsung dari
  // WA HP. Nilai: 'WA_DIRECT' | 'WEB_DASHBOARD' | 'AI' | null. Null untuk
  // pesan lama (pre-feature) atau pesan customer.
  source          String?
  // ID pesan dari Baileys (msg.key.id) — dipakai untuk dedup saat event
  // messages.upsert masuk untuk pesan yang baru saja kita kirim sendiri.
  externalMsgId   String?
  createdAt       DateTime      @default(now())

  contact   Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  waSession WhatsappSession @relation(fields: [waSessionId], references: [id])

  @@index([contactId, createdAt])
  @@index([waSessionId, createdAt])
  @@index([createdAt])
  @@index([externalMsgId])
}

// ─────────────────────────────────────────
// BROADCAST
// ─────────────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Broadcast {
  id           String          @id @default(cuid())
  userId       String
  waSessionId  String
  name         String
  message      String          @db.Text
  targetTags   String[]        @default([]) // tag kontak yang dituju
  targetStages String[]        @default([]) // pipeline stage yang dituju
  status       BroadcastStatus @default(DRAFT)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  totalTargets Int             @default(0)
  totalSent    Int             @default(0)
  totalFailed  Int             @default(0)
  createdAt    DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  waSession WhatsappSession @relation(fields: [waSessionId], references: [id])
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

// Diskriminator: pembelian token (default lama) vs upgrade paket LP.
// Existing rows otomatis di-default TOKEN_PURCHASE supaya backward compatible.
enum PaymentPurpose {
  TOKEN_PURCHASE
  LP_UPGRADE
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  orderId       String        @unique // merchant_ref yang dikirim ke Tripay
  amount        Int // dalam Rupiah
  tokenAmount   Int // jumlah token (TOKEN_PURCHASE) — 0 untuk LP_UPGRADE
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  reference     String?       @unique // reference dari Tripay (T0001xxxxx)
  paymentUrl    String? // checkout_url Tripay untuk redirect user
  payCode       String? // VA number atau kode bayar convenience store (DIRECT channels)
  paymentName   String? // Nama channel human-readable, mis. "BRI Virtual Account"
  paidAt        DateTime?
  expiredAt     DateTime?
  createdAt     DateTime      @default(now())

  // Polymorphic: TOKEN_PURCHASE pakai tokenAmount; LP_UPGRADE pakai lpPackageId.
  // Konsistensi (purpose vs FK) divalidasi di API layer karena Prisma
  // tidak support CHECK constraint native.
  purpose     PaymentPurpose    @default(TOKEN_PURCHASE)
  lpPackageId String?
  lpPackage   LpUpgradePackage? @relation(fields: [lpPackageId], references: [id])

  @@index([userId, status])
  @@index([orderId])
  @@index([purpose, status])
}

// ─────────────────────────────────────────
// TOKEN PACKAGE (diset admin)
// ─────────────────────────────────────────

model TokenPackage {
  id          String   @id @default(cuid())
  name        String // "Starter", "Popular", "Power"
  tokenAmount Int // jumlah token
  price       Int // harga dalam Rupiah
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  manualPayments ManualPayment[]
}

// ─────────────────────────────────────────
// MANUAL PAYMENT (Transfer Bank)
// ─────────────────────────────────────────

enum ManualPaymentStatus {
  PENDING // Menunggu verifikasi admin/finance
  CONFIRMED // Sudah diverifikasi & token sudah ditambahkan
  REJECTED // Ditolak oleh admin/finance
}

model ManualPayment {
  id              String              @id @default(cuid())
  userId          String
  // packageId nullable supaya bisa polymorphic — TOKEN_PURCHASE pakai packageId
  // (TokenPackage), LP_UPGRADE pakai lpPackageId (LpUpgradePackage).
  packageId       String?
  amount          Int // harga paket (Rupiah)
  tokenAmount     Int // jumlah token paket (0 untuk LP_UPGRADE)
  uniqueCode      Int // 100-999 untuk identifikasi transfer
  totalAmount     Int // amount + uniqueCode
  proofUrl        String? // URL bukti transfer (upload setelah create)
  proofNote       String?             @db.Text
  status          ManualPaymentStatus @default(PENDING)
  rejectionReason String?             @db.Text
  confirmedBy     String? // userId admin/finance yang konfirmasi
  confirmedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Polymorphic — sama logika dengan Payment.
  purpose     PaymentPurpose @default(TOKEN_PURCHASE)
  lpPackageId String?

  user      User              @relation("UserManualPayments", fields: [userId], references: [id], onDelete: Cascade)
  package   TokenPackage?     @relation(fields: [packageId], references: [id])
  lpPackage LpUpgradePackage? @relation(fields: [lpPackageId], references: [id])
  confirmer User?             @relation("ConfirmedByUser", fields: [confirmedBy], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([purpose, status])
}

// ─────────────────────────────────────────
// BANK ACCOUNT (Rekening tujuan transfer manual — diset admin)
// ─────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String // mis. "BCA", "Mandiri"
  accountNumber String
  accountName   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────
// LANDING PAGE BUILDER
// ─────────────────────────────────────────

// Tier kuota LP — naik otomatis berdasarkan total token yang pernah dibeli.
// FREE = default user baru. STARTER/POPULAR/POWER selaras dengan paket token.
enum LpTier {
  FREE
  STARTER
  POPULAR
  POWER
}

model LandingPage {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String   @unique // URL public, mis. /lp/<slug>
  htmlContent String   @db.Text
  metaTitle   String?
  metaDesc    String?  @db.Text
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images        LpImage[]
  visits        LpVisit[]
  events        LpEvent[]
  heatmapBins   LpHeatmapBin[]
  chatSignals   LpChatSignal[]
  generations   LpGeneration[]
  optimizations LpOptimization[]
  versions      LpVersion[]
  scores        LpScore[]
  contentIdeas  ContentIdea[]
  contentBriefs ContentBrief[]

  @@index([userId, isPublished])
}

model LpImage {
  id           String   @id @default(cuid())
  userId       String
  // Boleh null — user bisa upload ke library dulu, baru pasang di LP nanti.
  lpId         String?
  filename     String // nama file di disk (mis. <random>.jpg)
  originalName String
  url          String // /uploads/lp-images/<userId>/<filename>
  size         Int // bytes
  mimeType     String
  createdAt    DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lp   LandingPage? @relation(fields: [lpId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([lpId])
}

// LpScore — cache + history per compute. Setiap kali score di-compute (manual
// refresh atau cron daily), insert row baru dengan total + breakdown + meta.
//
// Latest score: ORDER BY computedAt DESC LIMIT 1 per lpId.
// Score-over-time chart: range query untuk anchor points di trend graph.
//
// Stale handling: API GET cek umur latest row — kalau >24 jam, recompute
// on-demand (lazy refresh).
model LpScore {
  id            String @id @default(cuid())
  landingPageId String

  // Total 0-100 (derived dari sum breakdown — disimpan supaya gampang sort/query).
  total Int

  // Per-dimensi breakdown (struct JSON):
  // { traffic: {score, max, detail}, engagement: {...}, conversion: {...},
  //   content: {...}, technical: {...}, sentiment: {...} }
  breakdownJson Json @default("{}")

  // Window data yang dipakai compute (mis. 30 hari, 7 hari).
  periodDays Int @default(30)

  // Visit count yang ada di window — kalau < threshold, score "below confidence".
  // Disimpan supaya UI bisa show disclaimer "data minim".
  sampleVisits Int @default(0)

  // Trigger: 'manual' (user klik refresh), 'cron' (daily), 'apply' (snapshot
  // saat apply optimization untuk before/after compare).
  trigger String @default("cron")

  computedAt DateTime @default(now())

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId, computedAt(sort: Desc)])
}

// LpOptimization — audit per call AI optimization Phase 4. Dicatat per call:
// model, token actual, cost provider, platform token charge, suggestions JSON,
// score estimate before/after, dan apakah user apply atau discard.
//
// Kalau apply: snapshot HTML before/after juga disimpan supaya bisa rollback
// langsung dari record ini (selain via LpVersion). Kalau discard: tidak charge
// token, hanya log (untuk audit perubahan minat user).
model LpOptimization {
  id     String @id @default(cuid())
  lpId   String
  userId String

  // Sonnet — model paling cocok untuk reasoning (CRO suggestions). Snapshot
  // supaya audit historis tetap akurat kalau model di-switch.
  model        String
  inputTokens  Int
  outputTokens Int

  inputPricePer1MUsd  Float @default(0)
  outputPricePer1MUsd Float @default(0)
  providerCostUsd     Float @default(0)
  providerCostRp      Float @default(0)
  // Platform tokens yang di-charge ke user balance. 0 kalau discard.
  platformTokensCharged Int @default(0)

  // Output AI — di-validate parse JSON sebelum simpan.
  suggestionsJson Json   @default("[]") // [{title, rationale, impact}]
  focusAreasJson  Json   @default("[]") // ["pricing","social_proof",...]
  scoreBefore     Int? // estimasi 0-100 dari AI atas LP saat ini
  scoreAfter      Int? // estimasi setelah perbaikan diterapkan
  // Konteks input yg di-feed ke AI — disimpan untuk transparency & debug.
  contextSummary  String? @db.Text

  // Apply state
  applied         Boolean   @default(false)
  appliedAt       DateTime?
  // Snapshot HTML — beforeHtml selalu disimpan, afterHtml hanya kalau output
  // valid. Kedua field nullable supaya record tetap bisa dibuat saat error.
  beforeHtml      String?   @db.Text
  afterHtml       String?   @db.Text
  // Link ke LpVersion yang ter-create saat apply. Null kalau discard.
  appliedVersionId String?

  errorMessage String? @db.Text
  createdAt    DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lp   LandingPage @relation(fields: [lpId], references: [id], onDelete: Cascade)

  @@index([lpId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// LpVersion — snapshot HTML LP per perubahan signifikan. Source: 'manual'
// (user save manual edit), 'ai' (apply AI optimization), 'restore' (revert
// dari versi lain).
//
// Auto-prune: keep last 20 versi per LP — yang lebih lama dihapus oleh cron
// /api/cron/cleanup-lp.
model LpVersion {
  id          String @id @default(cuid())
  lpId        String
  // Snapshot full HTML saat versi ini dibuat.
  htmlContent String @db.Text
  // Source tag untuk filter di UI history.
  source      String // manual | ai | restore
  // Optional reference: kalau source=ai, point ke LpOptimization yang trigger.
  optimizationId String?
  // Score estimate snapshot — dari evaluator (Phase 5) atau AI optimization estimate.
  scoreSnapshot  Int?
  // Note opsional dari user atau auto-generated ("Apply AI suggestions").
  note        String? @db.Text

  createdAt DateTime @default(now())

  lp LandingPage @relation(fields: [lpId], references: [id], onDelete: Cascade)

  @@index([lpId, createdAt(sort: Desc)])
}

// Audit per-call AI generation untuk LP. Dicatat per generation supaya bisa
// tracking biaya provider (token Anthropic × harga model) terpisah dari token
// platform yang di-charge. Token platform = TokenTransaction (USAGE = -10);
// di sini disimpan input/output token aktual + estimasi biaya USD/Rp untuk
// reporting & sanity check apakah harga 10 token/generate masih cover biaya
// AI provider.
model LpGeneration {
  id     String @id @default(cuid())
  lpId   String
  userId String

  // Model yang dipakai (mis. claude-haiku-4-5). Disimpan supaya kalau model
  // di-switch nanti, history tetap accurate per call.
  model        String
  inputTokens  Int
  outputTokens Int

  // Harga snapshot per 1M token (USD) saat call ini di-fire. Snapshot supaya
  // perubahan harga provider di masa depan tidak ngerusak audit historis.
  inputPricePer1MUsd  Float @default(0)
  outputPricePer1MUsd Float @default(0)
  // Hasil compute: provider cost dalam USD & Rp (pakai usdRate snapshot dari
  // PricingSettings saat call). Dua-duanya disimpan supaya UI tidak perlu
  // re-compute setiap render.
  providerCostUsd     Float @default(0)
  providerCostRp      Float @default(0)
  // Token platform yang di-charge ke user untuk panggilan ini. Sumber kebenaran
  // billing tetap di TokenTransaction; field ini sekadar mirror untuk JOIN-free
  // reporting.
  platformTokensCharged Int @default(0)

  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lp   LandingPage @relation(fields: [lpId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([lpId, createdAt(sort: Desc)])
}

// Kuota LP & storage per user. Tier hanya naik (lihat lib/lp-quota.ts).
model UserQuota {
  userId          String   @id
  tier            LpTier   @default(FREE)
  maxLp           Int      @default(1)
  maxStorageMB    Int      @default(5)
  storageUsedMB   Float    @default(0)
  // Per-image limit (MB) — beda dgn maxStorageMB (total). Free user dibatasi
  // upload kecil supaya gambar gigantes tidak makan storage cepat.
  maxImageSizeMB  Int      @default(1)
  // Visitor cap bulanan untuk LP user ini. Free user dibatasi 1k/bln supaya
  // bandwidth tidak boncos kalau ada LP yg viral.
  maxVisitorMonth Int      @default(1000)
  // Apakah user boleh pakai AI generate. Free user OFF — harus upgrade.
  // Selain itu ada token threshold check di /api/lp/generate.
  canAiGenerate   Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tracking pengunjung public LP. Dipakai untuk:
// 1. Throttle per-IP (10 visit/menit/IP/LP) — cegah scrape/DoS
// 2. Cap bulanan per plan user (UserQuota.maxVisitorMonth)
// 3. Analytics owner LP
//
// IP di-hash dgn SHA256 + IP_SALT (bukan plaintext) untuk privacy + GDPR.
// Auto-cleanup >90 hari via cron /api/cron/cleanup-lp.
model LpVisit {
  id            String   @id @default(cuid())
  landingPageId String
  ipHash        String
  userAgent     String?  @db.Text
  referer       String?  @db.Text
  createdAt     DateTime @default(now())

  // ── LP Lab fields (2026-05-09) — engagement data per visit ──
  // Extracted dari User-Agent saat insert (server-side, lightweight regex).
  // Nullable supaya LpVisit lama (sebelum LP Lab) tetap valid.
  deviceType String? // MOBILE | TABLET | DESKTOP | BOT
  browser    String? // Chrome | Safari | Firefox | dst
  os         String? // iOS | Android | Windows | macOS | Linux | dst

  // Geoip (best-effort dari header reverse proxy atau API eksternal).
  // Bisa null kalau lookup gagal / belum di-setup.
  country String?
  city    String?

  // Engagement aggregates — di-update oleh tracker JS via /api/lp/events.
  // Visit baru default null/false, sampai event scroll/click/unload datang.
  scrollMaxPct   Int? // 0-100, max scroll yg pernah dicapai
  timeOnPageSec  Int? // estimated dari last-event minus pageview, capped 30 menit
  ctaClicked     Boolean @default(false) // any CTA clicked di visit ini
  bounced        Boolean @default(true) // default true; false saat scrollMaxPct >= 25 OR timeOnPageSec >= 10

  // UTM dari URL — hadir kalau visitor datang via campaign tracking.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Last activity timestamp untuk hitung session duration. Diupdate per
  // event datang. NULL = visit cuma pageview tanpa engagement event.
  lastEventAt DateTime?

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  events      LpEvent[]

  @@index([landingPageId, createdAt])
  @@index([ipHash, landingPageId, createdAt])
  @@index([landingPageId, deviceType])
}

// LpHeatmapBin — aggregated click positions per grid cell. Storage strategy:
// alih-alih simpan setiap click point (akan explode), kita bin ke 100×100
// grid cell (1% resolution). Per device type beda layout, jadi key terdiri
// dari (lpId, deviceType, xCell, yCell) — count incremented per click event
// yang masuk ke cell itu.
//
// Heatmap.js rendering di UI: ambil semua bin untuk lpId+deviceType+period,
// render dot per bin dengan radius+intensity proportional ke count.
//
// Cleanup: bin lebih dari 90 hari tidak di-purge — count tetap akurat
// (hanya freshness yang menurun). Kalau butuh, tambah field updatedAt + cron
// purge bin yang updatedAt < 90 hari ago.
model LpHeatmapBin {
  id            String @id @default(cuid())
  landingPageId String
  // MOBILE | TABLET | DESKTOP — null tidak di-track (BOT events di-skip).
  deviceType    String
  // 0-99 grid coords relative to (page width, page height) saat klik.
  xCell         Int
  yCell         Int
  count         Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, deviceType, xCell, yCell])
  @@index([landingPageId, deviceType])
}

// LpChatSignal — aggregated customer concern signal per LP. Sumber: pesan WA
// dari Contact yang convert dari LP (matched via UTM utm_source=lp_<slug>
// di UserOrder, atau via OrderForm yang attached ke LP).
//
// Signal di-bucketing pakai keyword (lib/services/lp-chat-signals.ts):
//   harga_mahal, gak_paham, gak_percaya, ragu_kualitas, gak_yakin, cocok_kebutuhan
//
// Update via cron daily — recompute count + sample 3 quote per bucket.
// Quote di-anonymized (cuma snippet 80 char dari pesan customer).
//
// Period field = compute window (7d/30d) supaya bisa display "30 hari terakhir"
// vs "7 hari terakhir" tanpa double-counting.
model LpChatSignal {
  id            String @id @default(cuid())
  landingPageId String
  category      String // harga_mahal | gak_paham | gak_percaya | ragu_kualitas | gak_yakin | cocok_kebutuhan
  count         Int    @default(0)
  // Sample quotes anonymized (max 3, max 80 char each), JSON array of strings.
  // Dipakai UI tampil sample concern + jadi konteks AI optimization Phase 4.
  sampleQuotes  Json   @default("[]")
  // Window: 7 atau 30 hari (default 30).
  periodDays    Int    @default(30)

  computedAt DateTime @default(now())

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, category, periodDays])
  @@index([landingPageId])
}

// LpEvent — granular tracker event per visit. Sumber data utama untuk
// analytics dashboard dan AI optimization (CTR, scroll depth distribution,
// CTA ranking, bounce funnel).
//
// Event types yang di-track tracker JS:
//   pageview        — fire saat tracker boot (supplementary; LpVisit sudah
//                     dibuat server-side di /p/<slug>). Di-skip oleh ingestion
//                     karena duplikat.
//   scroll_25/50/75/100 — milestone scroll depth
//   cta_click       — klik tombol/link CTA. value = label tombol
//   outbound_click  — klik link eksternal (wa.me, mailto, http://...). value = URL host
//   form_submit     — submit form di LP. value = form action atau "form_inline"
//   time_milestone  — sampling 30s/60s/120s untuk engagement quality
//   page_unload     — fire saat user close tab/navigate away. value = total seconds di page
//
// Tidak track field input value, tidak track full mouse path. Mouse coords
// untuk heatmap di-aggregate ke LpHeatmapBin (terpisah, Phase 3).
model LpEvent {
  id            String  @id @default(cuid())
  landingPageId String
  // Link ke LpVisit kalau bisa di-resolve via visitToken. Nullable supaya
  // event yg datang dari visit lama (LpVisit sudah expired/deleted) tetap
  // bisa di-insert untuk count agregat.
  visitId       String?

  eventType   String // lihat docs di atas model
  eventValue  String? @db.Text // payload string opsional (label CTA, URL host, dll)
  scrollPct   Int? // 0-100 saat event terjadi
  timeOnPageSec Int? // detik sejak pageview saat event terjadi

  // Repeat fields penting supaya bisa query LpEvent tanpa JOIN ke LpVisit.
  ipHash     String
  deviceType String?
  createdAt  DateTime @default(now())

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  visit       LpVisit?    @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([landingPageId, eventType, createdAt])
  @@index([landingPageId, createdAt])
  @@index([visitId])
}

// ─────────────────────────────────────────
// LANDING PAGE UPGRADE PACKAGES (diset admin)
// ─────────────────────────────────────────

// Paket upgrade tier kuota LP yang bisa user beli langsung. Beda dengan
// upgrade otomatis dari token purchase (lihat lib/lp-quota.ts) — paket ini
// di-purchase sebagai LP_UPGRADE Payment/ManualPayment dan langsung set
// UserQuota.tier+maxLp+maxStorageMB sesuai paket.
model LpUpgradePackage {
  id                String   @id @default(cuid())
  name              String // "Starter", "Popular", "Power"
  description       String?
  tier              LpTier
  maxLp             Int
  maxStorageMB      Int
  // Harga one-time legacy. Per Mei 2026 sistem pakai subscription bulanan,
  // tapi field ini dipertahankan untuk grandfathered user yg sudah upgrade
  // sebelum subscription system + display di history.
  price             Int // dalam Rupiah
  // Harga subscription per bulan (Rupiah). Default 0 = belum disetel admin
  // (paket ini di-skip di /pricing). Hitung total = priceMonthly × durationMonths,
  // lalu apply diskon dari DURATION_DISCOUNTS (lihat lib/subscription-pricing.ts).
  priceMonthly      Int      @default(0)
  isPopular         Boolean  @default(false)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  // Akses Order System (Phase 1, 2026-05-07): Form Order, Invoice Otomatis,
  // Multi-Payment, Subsidi Ongkir, Flash Sale. Default false untuk semua paket;
  // di-set true HANYA untuk paket POWER via seed.
  canUseOrderSystem Boolean  @default(false)
  createdAt         DateTime @default(now())

  payments       Payment[]
  manualPayments ManualPayment[]
  subscriptions  Subscription[]

  @@index([isActive, sortOrder])
}

// ─────────────────────────────────────────
// SUBSCRIPTION (Prepaid Bulanan)
// ─────────────────────────────────────────

// Subscription user ke paket LP. Prepaid model: user bayar di muka 1/3/6/12
// bulan, dapat diskon untuk durasi panjang (lihat lib/subscription-pricing.ts).
//
// Status:
//   PENDING   = invoice belum dibayar (atau belum dikonfirmasi admin)
//   ACTIVE    = sudah dibayar, akses fitur premium aktif sampai endDate
//   EXPIRED   = endDate lewat, user otomatis turun ke FREE (cron daily)
//   CANCELLED = user/admin cancel; tetap aktif sampai endDate (no refund)
//
// `isLifetime` true untuk grandfathered user yg sudah upgrade lewat
// LpUpgradePackage one-time SEBELUM subscription system live. endDate
// diset ke 2099-12-31 supaya tidak pernah expire. durationMonths = 999.
model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lpPackageId String
  lpPackage   LpUpgradePackage @relation(fields: [lpPackageId], references: [id])

  durationMonths Int // 1 | 3 | 6 | 12 | 999 (lifetime)
  isLifetime     Boolean  @default(false)
  startDate      DateTime
  endDate        DateTime

  // String biasa, bukan enum, supaya gampang nambah state baru tanpa migrate.
  status String @default("PENDING")

  priceBase   Float @default(0) // total tanpa diskon (priceMonthly × durationMonths)
  discountPct Float @default(0)
  priceFinal  Float @default(0) // setelah diskon, di-bulatkan ke ratusan rupiah

  invoices SubscriptionInvoice[]

  cancelledAt     DateTime?
  cancelledReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([endDate, status])
}

// Invoice per pembayaran subscription. Satu Subscription bisa punya banyak
// invoice (mis. user perpanjang → invoice baru, status ACTIVE tetap di
// subscription induk). Status PENDING bisa transisi ke WAITING_CONFIRMATION
// (manual transfer, sudah upload bukti) → PAID (admin approve) atau ke
// EXPIRED (24 jam tidak dibayar).
model SubscriptionInvoice {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique
  amount        Float // Total final yg harus dibayar (untuk manual transfer
  // includes uniqueCode supaya gampang identify)
  uniqueCode    Int    @default(0) // 100-999, untuk manual transfer identification
  description   String @db.Text

  status String    @default("PENDING")
  // PENDING | WAITING_CONFIRMATION | PAID | EXPIRED | CANCELLED
  paidAt DateTime?

  paymentMethod String // TOKEN_BALANCE (current default) | TRIPAY | MANUAL_TRANSFER (legacy, grandfathered)

  // Token payment (paymentMethod=TOKEN_BALANCE) — jumlah token yg dipotong
  // dari saldo user saat checkout. Konversi dari amount IDR pakai
  // PricingSettings.pricePerToken aktif saat checkout (di-snapshot supaya
  // audit historis akurat kalau pricePerToken berubah).
  tokenAmount Int?

  // Tripay fields (paymentMethod=TRIPAY) — legacy, grandfathered.
  tripayReference   String?
  tripayMerchantRef String? @unique
  paymentUrl        String? @db.Text
  paymentChannel    String? // BCA_VA, BNI_VA, QRIS, OVO, etc

  // Manual transfer fields (paymentMethod=MANUAL_TRANSFER) — legacy, grandfathered.
  manualProofUrl String? // /uploads/payment-proofs/<filename>
  manualNote     String?   @db.Text
  approvedBy     String? // userId admin yg approve
  approvedByUser User?     @relation("ApprovedSubscriptionInvoice", fields: [approvedBy], references: [id])
  approvedAt     DateTime?

  expiresAt DateTime // 24 jam dari create
  createdAt DateTime @default(now())

  @@index([invoiceNumber])
  @@index([status, expiresAt])
  @@index([subscriptionId, status])
}

// In-app + WA notification log. type: PAYMENT_SUCCESS, PAYMENT_FAILED,
// EXPIRING_7D, EXPIRING_3D, EXPIRING_1D, EXPIRED. channel: IN_APP, WA, EMAIL.
//
// Cron reminder cek existing record per (userId, subscriptionId, type) untuk
// idempotency — tidak dobel kirim notifikasi sama.
model SubscriptionNotification {
  id             String  @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?

  type    String
  channel String @default("IN_APP")

  title   String
  message String  @db.Text
  // Optional URL yg dituju saat user klik notifikasi.
  link    String?

  sentAt DateTime?
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, subscriptionId, type])
}

// ─────────────────────────────────────────
// SITE SETTINGS (key-value, diset admin)
// ─────────────────────────────────────────

// Setting platform yang fleksibel — key-value supaya gampang nambah field baru
// tanpa migrate. Contoh key: WA_ADMIN, PLATFORM_NAME, SUPPORT_EMAIL.
model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// AI PRICING DATABASE (preset harga API per model)
// ─────────────────────────────────────────

// Source-of-truth harga API. Bisa di-update manual atau via AI research
// (lihat lib/services/ai-pricing-research.ts). Form /admin/models pakai
// table ini untuk dropdown + auto-fill harga.
model AiModelPreset {
  id                String   @id @default(cuid())
  provider          String // ANTHROPIC | OPENAI | GOOGLE
  modelId           String   @unique
  displayName       String
  inputPricePer1M   Float // USD per 1M token
  outputPricePer1M  Float
  contextWindow     Int?
  isAvailable       Boolean  @default(true)
  notes             String?
  // 'manual' = admin edit langsung; 'ai-research' = update via Claude
  // web_search; 'seed' = data awal saat migration.
  lastUpdatedSource String?
  lastUpdatedAt     DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([provider, isAvailable])
}

// Audit trail untuk job research. Dipakai juga sebagai status holder saat
// research async berjalan (status RUNNING → SUCCESS / FAILED).
model PricingResearchLog {
  id            String    @id @default(cuid())
  triggeredBy   String // userId admin (atau 'cron' kalau scheduled)
  status        String // RUNNING | SUCCESS | FAILED
  modelsAdded   Int       @default(0)
  modelsUpdated Int       @default(0)
  // Hasil mentah dari Claude (JSON yang di-parse atau raw text kalau parse
  // gagal). Untuk debugging.
  rawResponse   String?   @db.Text
  // Hasil terstruktur — array { id, action, before, after } untuk apply.
  diff          Json?
  error         String?   @db.Text
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([startedAt])
}

// ─────────────────────────────────────────
// PRICING SETTINGS (singleton, dipakai admin tools + wa-service untuk
// hitung biaya & rekomendasi token per pesan)
// ─────────────────────────────────────────

// Singleton — selalu 1 row. Akses via lib/pricing-settings.ts:getPricingSettings().
model PricingSettings {
  id                    String   @id @default(cuid())
  // Target margin minimum (%) yang dipakai mode AUTO di AiModel untuk hitung
  // costPerMessage. Juga jadi threshold status badge di UI.
  marginTarget          Float    @default(50)
  // Estimasi rata-rata token per balasan AI (dipakai saat hitung
  // costPerMessage rekomendasi sebelum ada data riil).
  estimatedInputTokens  Int      @default(1600)
  estimatedOutputTokens Int      @default(300)
  // Kurs USD→IDR. Update saat dollar bergerak signifikan supaya cost akurat.
  usdRate               Float    @default(16000)
  // Harga jual platform per 1 token (IDR). Dipakai untuk hitung pendapatan
  // dan rekomendasi.
  pricePerToken         Float    @default(2)
  updatedAt             DateTime @updatedAt
}

// ─────────────────────────────────────────
// ALERTS (profitability monitor)
// ─────────────────────────────────────────

// Generate oleh /api/cron/profitability-check, ditampilkan di sidebar admin
// (bell icon) sampai admin tandai sudah dibaca.
model Alert {
  id        String   @id @default(cuid())
  level     String // 'RED' | 'YELLOW' | 'GREEN'
  category  String // 'PROFIT_NEGATIVE' | 'MARGIN_LOW' | 'ANOMALY'
  title     String
  message   String   @db.Text
  metadata  Json? // bebas — biasanya { modelId, profitRp, marginPct, ... }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// ─────────────────────────────────────────
// API KEYS (provider AI — encrypted di DB)
// ─────────────────────────────────────────

// Satu row per provider (ANTHROPIC/OPENAI/GOOGLE). apiKey di-encrypt dengan
// AES-256-GCM (lib/crypto.ts) memakai ENCRYPTION_KEY dari env. Halaman
// /admin/api-keys mengelola CRUD + test koneksi. wa-service mengambil key
// (sudah di-decrypt) lewat internal API supaya satu sumber kebenaran.
model ApiKey {
  id             String    @id @default(cuid())
  provider       String    @unique // 'ANTHROPIC' | 'OPENAI' | 'GOOGLE'
  apiKey         String    @db.Text
  isActive       Boolean   @default(true)
  lastTestedAt   DateTime?
  lastTestStatus String? // 'SUCCESS' | 'FAILED'
  lastTestError  String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─────────────────────────────────────────
// SOUL TESTING LAB — Simulasi 2 AI (Penjual vs Pembeli) untuk uji efektivitas
// Soul. Dipanggil admin dari /admin/soul-lab. Engine: lib/services/soul-simulation.ts
// ─────────────────────────────────────────

enum SoulSimulationStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SoulSimulationOutcome {
  SOLD
  REJECTED
  INCONCLUSIVE
}

enum SoulSimulationRole {
  SELLER
  BUYER
}

model SoulSimulation {
  id          String @id @default(cuid())
  triggeredBy String
  triggerUser User   @relation(fields: [triggeredBy], references: [id], onDelete: Cascade)

  // Setup penjual (agen yang mau di-test)
  // sellerSoulId — LEGACY (dipakai sebelum migrasi Personality+Style). Nullable
  // supaya row baru bisa skip; row lama tetap kebaca buat history.
  sellerSoulId        String?
  sellerSoul          Soul?            @relation("SimSellerSoul", fields: [sellerSoulId], references: [id])
  sellerPersonalityId String?
  sellerPersonality   SoulPersonality? @relation("SimSellerPersonality", fields: [sellerPersonalityId], references: [id])
  sellerStyleId       String?
  sellerStyle         SoulStyle?       @relation("SimSellerStyle", fields: [sellerStyleId], references: [id])
  sellerModelId       String
  sellerModel         AiModel          @relation("SimSellerModel", fields: [sellerModelId], references: [id])
  sellerContext       String           @db.Text // konteks bisnis: produk, harga, promo

  // Setup pembeli (lawan main) — sama strukturnya dengan penjual.
  buyerSoulId        String?
  buyerSoul          Soul?            @relation("SimBuyerSoul", fields: [buyerSoulId], references: [id])
  buyerPersonalityId String?
  buyerPersonality   SoulPersonality? @relation("SimBuyerPersonality", fields: [buyerPersonalityId], references: [id])
  buyerStyleId       String?
  buyerStyle         SoulStyle?       @relation("SimBuyerStyle", fields: [buyerStyleId], references: [id])
  buyerModelId       String
  buyerModel         AiModel          @relation("SimBuyerModel", fields: [buyerModelId], references: [id])
  buyerScenario      String           @db.Text // skenario pembeli: situasi, motivasi, keberatan

  // Pengaturan jalannya simulasi
  totalRounds    Int                @default(10)
  starterRole    SoulSimulationRole
  starterMessage String             @db.Text

  // Knowledge entries yang dipakai seller saat simulasi (mirror behavior
  // produksi: retrieveRelevantKnowledge by keyword vs pesan buyer). Admin
  // pilih cherry-pick dari UserKnowledge berbagai user supaya bisa test
  // skenario yang akurat. Kosong = tanpa knowledge (default lama).
  // FK lunak (string array) — life-cycle independen, kalau entry dihapus
  // engine tinggal skip yang tidak ada.
  sellerKnowledgeIds String[] @default([])

  // Status (string supaya gampang transition: RUNNING → COMPLETED/FAILED/CANCELLED)
  status       SoulSimulationStatus @default(RUNNING)
  currentRound Int                  @default(0)
  errorMessage String?              @db.Text

  // Hasil percakapan (JSON array: { role, content, timestamp, tokens })
  conversation    Json                   @default("[]")
  evaluationScore Float?
  evaluationData  Json?
  outcome         SoulSimulationOutcome?

  // Cost tracking — dibebankan ke triggerUser
  totalInputTokens  Int   @default(0)
  totalOutputTokens Int   @default(0)
  totalCostRp       Float @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([triggeredBy, createdAt])
  @@index([status, createdAt])
  @@index([sellerSoulId])
  @@index([sellerPersonalityId])
}

// ─────────────────────────────────────────
// USER SALES FLOW — alur otomatis (COD, Transfer, Booking, Konsultasi, Custom)
// yang dijalankan saat keyword trigger cocok dengan pesan customer. Saat flow
// aktif, balasan diatur script (hemat token AI). Selesai → notif admin.
// ─────────────────────────────────────────

model UserSalesFlow {
  id     String @id @default(cuid())
  userId String

  name            String
  // COD | TRANSFER | BOOKING | CONSULTATION | CUSTOM — string supaya gampang
  // nambah template baru tanpa migrate.
  template        String
  description     String?
  triggerKeywords String[] @default([])

  // Array pertanyaan terurut. Tiap step: { fieldName, question, validation }.
  // Lihat lib/services/flow-engine.ts untuk daftar validation yang didukung.
  steps       Json @default("[]")
  // { notifyAdmin, adminPhone, replyMessage, bankInfo? } — lihat lib/sales-flow-templates.ts.
  finalAction Json @default("{}")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions OrderSession[]

  @@index([userId, isActive])
}

// State per-contact untuk flow yang sedang berjalan. Satu kontak hanya boleh
// punya satu OrderSession ACTIVE pada satu waktu (di-enforce di flow-engine).
model OrderSession {
  id        String @id @default(cuid())
  userId    String
  contactId String
  flowId    String

  currentStep   Int    @default(0)
  // Map fieldName → jawaban customer yang sudah divalidasi.
  collectedData Json   @default("{}")
  // ACTIVE | COMPLETED | ABANDONED | CANCELLED | FAILED
  status        String @default("ACTIVE")

  startedAt      DateTime  @default(now())
  // Diupdate tiap kali customer balas. Kalau > 30 menit lewat, otomatis
  // di-mark ABANDONED saat pesan baru masuk (lazy cleanup).
  lastActivityAt DateTime  @default(now())
  completedAt    DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  flow    UserSalesFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  order   UserOrder?

  @@index([userId, status])
  @@index([contactId, status])
  @@index([flowId, status])
}

// ─────────────────────────────────────────
// USER ORDER — pesanan customer yang sudah jadi (auto-create saat OrderSession
// completed, atau manual via API). Kolom paymentMethod & paymentStatus &
// deliveryStatus dipakai admin untuk track status pengiriman & pembayaran.
// ─────────────────────────────────────────

model UserOrder {
  id             String  @id @default(cuid())
  userId         String
  // Nullable per Phase 3 (2026-05-07): order dari OrderForm publik tidak
  // selalu match contact existing (customer belum chat via WA). Untuk
  // backward-compat, order dari WA flow tetap isi contactId.
  contactId      String?
  // Asal flow yang generate order ini. Null kalau dibuat manual atau flow
  // di-hapus belakangan (onDelete: SetNull).
  orderSessionId String? @unique

  customerName    String
  customerPhone   String
  customerAddress String? @db.Text

  // Array { name, qty, price? } — Phase 3 belum ada item collection di flow,
  // jadi default kosong. User bisa edit manual via UI atau Phase 4 nanti.
  items       Json    @default("[]")
  totalAmount Float?
  // Catatan dari customer saat order (mis. dari form publik). Search-able.
  notes       String? @db.Text
  // Catatan internal admin — TIDAK ditampilkan ke customer di invoice page.
  // Search-able di list pesanan.
  notesAdmin  String? @db.Text

  // Tags many-to-many. User pakai untuk segmentasi (VIP, Komplain, Repeat, dll).
  tags        OrderTag[] @relation("OrderTags")

  // COD | TRANSFER | BOOKING | CONSULTATION | FREE — string supaya gampang
  // nambah method baru tanpa migrate.
  paymentMethod   String
  // PENDING | PAID | CANCELLED.
  paymentStatus   String  @default("PENDING")
  paymentProofUrl String?

  // PENDING | PROCESSING | SHIPPED | DELIVERED | CANCELLED.
  deliveryStatus String  @default("PENDING")
  trackingNumber String?

  // Snapshot nama flow (mis. "Pengiriman COD") supaya tampil di UI tanpa join.
  flowName String?

  // ─────────────────────────────────────────
  // E-COMMERCE FIELDS (Phase 1 Order System, 2026-05-07)
  // Semua optional/default — order dari WA sales flow tetap pakai field di atas
  // tanpa breaking. Order dari OrderForm public mengisi field ini.
  // ─────────────────────────────────────────
  orderFormId   String?
  // Relasi ke OrderForm publik (kalau order via form share-link).
  // SetNull supaya order existing tidak ikut terhapus saat form di-delete.
  orderForm     OrderForm? @relation("OrderFormSubmissions", fields: [orderFormId], references: [id], onDelete: SetNull)
  invoiceNumber String?    @unique
  customerEmail String?

  shippingProvinceId   String?
  shippingProvinceName String?
  shippingCityId       String?
  shippingCityName     String?
  shippingAddress      String? @db.Text
  shippingPostalCode   String?

  subtotalRp          Float   @default(0)
  flashSaleDiscountRp Float   @default(0)
  shippingCourier     String?
  shippingService     String?
  shippingCostRp      Float   @default(0)
  shippingSubsidyRp   Float   @default(0)
  shippingEtd         String?
  totalRp             Float   @default(0)

  appliedZoneId   String?
  appliedZoneName String?

  bankAccountSnapshot Json?
  uniqueCode          Int?

  paymentNote     String? @db.Text
  cancelledReason String?

  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  // Bank Mutation Auto-Reader (Phase 1, 2026-05-08, BETA) — diisi saat
  // order ter-PAID otomatis lewat scraper bank. Null untuk PAID manual.
  autoConfirmedAt   DateTime?
  autoConfirmedBy   String? // BCA_AUTO | MOOTA | MANUAL (future-proof)
  matchedMutationId String? // FK lunak ke BankMutation.id, no @relation
  // supaya lifecycle independen + simple query.

  // ─────────────────────────────────────────
  // PIXEL TRACKING ATTRIBUTION (Phase 1 Pixel Tracking, 2026-05-07)
  // Click IDs di-capture dari URL params di public order form, dipakai untuk
  // server-side pixel match (Meta CAPI butuh fbc, Google butuh gclid, dll).
  // UTM untuk attribution analytics.
  // ─────────────────────────────────────────
  fbclid               String?
  gclid                String?
  ttclid               String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  // Timestamp saat pixel event sukses fire — untuk dedup & UI status.
  pixelLeadFiredAt     DateTime?
  pixelPurchaseFiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  orderSession   OrderSession?   @relation(fields: [orderSessionId], references: [id], onDelete: SetNull)
  pixelEventLogs PixelEventLog[]
  followUpQueue  FollowUpQueue[]
  // LMS Phase 1 — kalau item ada productId.courseId, hook on-PAID upsert
  // Enrollment dgn orderId=this.id supaya admin bisa trace order → akses.
  enrollments    Enrollment[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, paymentStatus])
  @@index([userId, deliveryStatus])
  @@index([invoiceNumber])
}

// Tag admin untuk segmentasi order (VIP, Komplain, Repeat Buyer, dll). Per-user
// scope. Many-to-many ke UserOrder via implicit join _OrderTags.
model OrderTag {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  // Hex color (#RRGGBB) untuk badge di UI.
  color     String @default("#6B7280")

  orders UserOrder[] @relation("OrderTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// Saved preference untuk halaman /pesanan — kolom yang aktif, urutan, sort,
// dan filter terakhir. Per-user, 1 record. Frontend save debounced.
model UserOrderViewPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Kunci kolom yang ditampilkan (subset dari ORDER_COLUMNS di lib/order-columns.ts).
  // Empty array = pakai default (DEFAULT_VISIBLE_COLUMNS).
  visibleColumns String[] @default([])
  // Urutan kolom (kalau drag-and-drop diaktifkan). Empty = pakai urutan
  // ORDER_COLUMNS bawaan.
  columnOrder    String[] @default([])

  // Snapshot filter terakhir dipakai (JSON object). Schema bebas — frontend
  // yang interpret. Format: { paymentStatus: ['PAID'], shippingCourier: ['jne'], ... }
  filters Json?

  // Sort kolom + arah. Kalau null, frontend default ke createdAt desc.
  sortColumn    String?
  sortDirection String?

  pageSize Int @default(50)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// USER KNOWLEDGE BASE — info bisnis (testimoni, sertifikat, FAQ, link, file)
// yang AI inject ke system prompt saat keyword di triggerKeywords match pesan
// customer. Dipakai supaya AI bisa kasih jawaban kontekstual + (opsional)
// kirim file pendukung.
// ─────────────────────────────────────────

model UserKnowledge {
  id     String @id @default(cuid())
  userId String

  title       String
  // TEXT | IMAGE | FILE | LINK — divalidasi di API layer (Zod), bukan enum
  // supaya gampang nambah jenis baru tanpa migrate schema.
  contentType String

  textContent String? @db.Text
  fileUrl     String? // /uploads/knowledge/<userId>/<filename>
  linkUrl     String?
  // Caption untuk IMAGE/FILE/LINK — dikirim AI saat attach atau jadi konteks.
  caption     String? @db.Text

  // Kata kunci pemicu. Postgres native string array (lihat Broadcast.targetTags).
  triggerKeywords String[] @default([])

  isActive        Boolean   @default(true)
  triggerCount    Int       @default(0)
  lastTriggeredAt DateTime?
  order           Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, order])
}

model SoulSimulationPreset {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Snapshot setup: { sellerSoulId, sellerModelId, sellerContext, buyerSoulId,
  // buyerModelId, buyerScenario, totalRounds, starterRole, starterMessage }
  config      Json
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([createdBy, createdAt])
}

// ─────────────────────────────────────────
// ORDER SYSTEM (Phase 1, 2026-05-07) — fitur khusus paket POWER:
// Form Order publik, Invoice otomatis, Multi-payment, Subsidi Ongkir,
// Flash Sale. Akses dijaga via LpUpgradePackage.canUseOrderSystem.
// ─────────────────────────────────────────

model Product {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  price       Float
  weightGrams Int     @default(500)
  // Cover image — auto-sync ke images[0] saat user upload multi. Tetap di-keep
  // sebagai field tunggal untuk consumer lama (invoice, orderCard, dll).
  imageUrl    String?
  // Galeri multi-image (max 10, di-enforce di Zod). Urutan = urutan tampil
  // di carousel di form publik. Item pertama = cover.
  images      String[] @default([])
  // null = unlimited stock (untuk produk digital atau pre-order).
  stock       Int?

  // Flash sale — disiapkan di Phase 1, dipakai di Phase 4. Aktif kalau
  // flashSaleActive=true DAN now di antara start/end DAN sold < quota.
  flashSalePrice   Float?
  flashSaleStartAt DateTime?
  flashSaleEndAt   DateTime?
  flashSaleQuota   Int?
  flashSaleSold    Int       @default(0)
  flashSaleActive  Boolean   @default(false)

  isActive Boolean @default(true)
  order    Int     @default(0)

  // Varian produk (Phase 5, 2026-05-08). Kalau array kosong → produk single
  // (pakai harga/stok/berat di field utama). Kalau ≥1 varian → customer
  // wajib pilih varian di form order, dan harga/stok/berat dipakai dari varian.
  variants ProductVariant[]

  // LMS link (Phase 1 LMS, 2026-05-09). Kalau set → produk ini = course.
  // Saat order PAID, hook auto-enrollment cek field ini dan upsert Enrollment
  // untuk customerPhone. 1:1 unique supaya 1 course = 1 product (per
  // arsitektur Phase 1; bundle pakai varian product).
  courseId String? @unique
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

// Varian produk — opsional. Setiap baris = satu kombinasi varian dengan
// nama bebas (mis. "12ml", "Putih - L", "Pink Besar"). User bisa edit nama
// label sebagai single-axis bebas; multi-axis dilakukan dengan nama gabungan
// supaya skema simple dan tidak butuh attribute matrix.
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Label yang ditampilkan ke customer di form order, mis. "30ml" atau "Hitam M".
  name        String
  // SKU opsional untuk inventaris. Tidak unique global karena per-user scope.
  sku         String?
  // Override price/weight/stock/image dari Product. Kalau null untuk imageUrl,
  // fall back ke product.imageUrl di UI. Tapi price/weight WAJIB diisi
  // (tidak diturunkan dari product) supaya pricing engine deterministik.
  price       Float
  weightGrams Int     @default(500)
  // null = unlimited stock (sama semantic seperti Product.stock).
  stock       Int?
  imageUrl    String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isActive, sortOrder])
}

// Multi-rekening user untuk terima transfer dari customer. Snapshot disalin
// ke UserOrder.bankAccountSnapshot saat order dibuat supaya invoice lama tetap
// valid walau user hapus rekening belakangan.
model UserBankAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankName      String // BCA, Mandiri, BRI, BNI, Permata, dll
  accountNumber String
  accountName   String

  isActive  Boolean @default(true)
  isDefault Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())

  @@index([userId, isActive])
}

// Profil pengiriman & WA konfirmasi per user. 1:1 dengan User. Kolom origin
// dipakai untuk hitung ongkir RajaOngkir dari kota asal user.
model UserShippingProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // RajaOngkir city ID kota asal pengiriman. Null sampai user setup di UI.
  originCityId       String?
  originCityName     String?
  originProvinceName String?

  // Whitelist kurir yang ditampilkan di form order public.
  enabledCouriers    String[] @default([]) // ['jne','sicepat','jnt','anteraja']
  defaultWeightGrams Int      @default(500)

  // WA confirmation: nomor user & template pesan untuk customer kirim bukti.
  // Format nomor: 6281234567890 (no '+', no '0' di depan).
  waConfirmNumber   String?
  waConfirmTemplate String? @db.Text
  waConfirmActive   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Form order publik. User bikin form, dapat slug, share link ke customer.
// Customer akses via /order/<slug> (no auth).
model OrderForm {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug        String   @unique
  name        String
  description String?  @db.Text
  // Subset Product.id yang ditampilkan. Kosong = tampilkan semua produk aktif user.
  productIds  String[] @default([])

  acceptCod       Boolean @default(true)
  acceptTransfer  Boolean @default(true)
  // Ongkir flat untuk COD (skip RajaOngkir). null = pakai RajaOngkir juga.
  shippingFlatCod Float?

  // false = produk digital, customer tidak perlu isi alamat & ongkir di-skip.
  requireShipping Boolean @default(true)

  showFlashSaleCounter Boolean @default(true)
  showShippingPromo    Boolean @default(true)

  // Social Proof popup (2026-05-08). Tampilkan notifikasi pembeli sebelumnya
  // di form publik. Data dari UserOrder PAID milik form owner.
  // Position: "top" | "bottom". IntervalSec: jeda antar popup (3-30 detik).
  socialProofEnabled     Boolean @default(false)
  socialProofPosition    String  @default("bottom")
  socialProofIntervalSec Int     @default(8)

  // PixelIntegration ID yang aktif untuk form ini (Phase 1 Pixel Tracking,
  // 2026-05-07). Multi-pixel — user bisa pakai 3 platform sekaligus per form.
  enabledPixelIds String[] @default([])

  isActive    Boolean @default(true)
  views       Int     @default(0)
  submissions Int     @default(0)

  // Back-relation untuk UserOrder.orderForm. Order yang submit via form ini
  // akan tampil di sini.
  userOrders UserOrder[] @relation("OrderFormSubmissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([userId])
}

// Aturan subsidi ongkir per zona. Match-nya by city ID atau province ID dari
// RajaOngkir. Priority tinggi menang kalau ada konflik (mis. "Bandung"
// vs "Jawa Barat" → Bandung lebih spesifik, set priority lebih tinggi).
model ShippingZone {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  // ALL = semua wilayah. CITY = match by cityIds. PROVINCE = match by provinceIds.
  matchType     String   @default("CITY")
  cityIds       String[] @default([])
  provinceIds   String[] @default([])
  // Snapshot nama untuk display tanpa fetch RajaOngkir lagi.
  cityNames     String[] @default([])
  provinceNames String[] @default([])

  // NONE = tidak ada subsidi. FLAT_AMOUNT = potong nominal tetap.
  // PERCENT = potong % dari ongkir. FREE = gratis ongkir penuh.
  subsidyType  String @default("NONE")
  subsidyValue Float  @default(0)
  // Syarat minimum subtotal produk supaya subsidi/free ongkir aktif.
  minimumOrder Float?

  startsAt DateTime?
  endsAt   DateTime?

  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

// Cache hasil hit RajaOngkir 6 jam supaya hemat quota (Starter 500 hit/hari).
// cacheKey format: "<originCityId>:<destCityId>:<weight>:<courierA,courierB>".
model ShippingCostCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  responseJson Json
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// ─────────────────────────────────────────
// PIXEL TRACKING (Phase 1, 2026-05-07) — fitur khusus paket POWER:
// Browser pixel + Server-side CAPI untuk Meta, Google Ads, TikTok.
// Encrypt accessToken dengan AES-256-GCM (lib/crypto.ts) sebelum simpan.
// ─────────────────────────────────────────

model PixelIntegration {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // META | GOOGLE_ADS | GA4 | TIKTOK — string biasa supaya gampang nambah
  // platform baru tanpa migrate enum.
  platform    String
  // Nama yg user lihat di list, mis. "Meta - Akun Cleanoz".
  displayName String

  // Browser pixel ID — bentuk berbeda per platform:
  //   META: 15-16 digit
  //   GA4: G-XXXXXXXXXX
  //   GOOGLE_ADS: AW-XXXXXXXXXX
  //   TIKTOK: C-style ID (mis. C12ABC34DEF56)
  pixelId String

  // Server-side (CAPI / Events API / Measurement Protocol)
  serverSideEnabled Boolean @default(false)
  // Encrypted dengan lib/crypto.ts (AES-256-GCM). Decrypt sebelum dipakai.
  accessToken       String? @db.Text

  // Google Ads specific (per-conversion label)
  conversionLabelInitiateCheckout String?
  conversionLabelLead             String?
  conversionLabelPurchase         String?

  // Test mode — Meta test events code untuk debug tanpa pollute prod data.
  testEventCode String?
  isTestMode    Boolean @default(false)

  isActive Boolean @default(true)

  // Stats — di-update saat event sukses fire.
  totalEvents Int       @default(0)
  lastEventAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventLogs PixelEventLog[]

  @@index([userId, platform])
  @@index([userId, isActive])
}

// Log SEMUA event yang di-fire (browser & server) untuk debug, audit, dan
// retry. eventId dipakai untuk dedup browser+server (Meta requirement).
model PixelEventLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nullable supaya log tetap ada walau pixel di-delete (debug history).
  pixelId String?
  pixel   PixelIntegration? @relation(fields: [pixelId], references: [id], onDelete: SetNull)

  orderId String?
  order   UserOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  platform  String
  eventName String // Purchase, Lead, AddPaymentInfo, ViewContent, dll
  // Stable ID per event — browser & server kirim eventId sama supaya Meta
  // dedup. Format: <eventName>_<orderId-or-sessionId>_<timestamp>.
  eventId   String

  // BROWSER = di-fire dari client via gtag/fbq/ttq.
  // SERVER = di-fire dari API route via CAPI/Events API.
  source String

  payload Json

  responseStatus Int?
  responseBody   String? @db.Text
  errorMessage   String? @db.Text

  retryCount Int     @default(0)
  succeeded  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([eventId])
  @@index([succeeded, retryCount])
}

// ─────────────────────────────────────────
// BANK MUTATION AUTO-READER (Phase 1 BETA, 2026-05-08) — fitur khusus paket
// POWER. Scraper container 'bank-scraper' login KlikBCA Individual via
// Puppeteer pakai kredensial user (encrypt AES-256-GCM, lib/crypto.ts),
// parse mutasi, auto-confirm UserOrder yang totalRp == amount mutasi CR.
//
// Risiko: ToS BCA, regulasi OJK, fraud detection. User pakai dengan disclaimer
// keras + opsi opt-in (isBetaConsented). Admin punya kill switch global.
// ─────────────────────────────────────────

model BankMutationIntegration {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // BCA only untuk MVP — string supaya gampang nambah bank lain.
  bankCode String @default("BCA")

  // Encrypted dengan lib/crypto.ts (AES-256-GCM). Format: <iv>:<tag>:<data>.
  // Decrypt hanya di scraper service saat login, jangan ekspos ke client.
  bcaUserId String @db.Text
  bcaPin    String @db.Text

  // Account info — di-fetch dari halaman mutasi BCA saat scrape pertama
  // sukses. Null sampai itu terjadi.
  accountNumber  String?
  accountName    String?
  accountBalance Float?

  // Cookie session BCA (encrypted JSON). Reuse selagi belum expire supaya
  // tidak harus login ulang setiap scrape (login = paling rawan kena flag).
  cookieData       String?   @db.Text
  sessionExpiresAt DateTime?

  isActive        Boolean @default(true)
  // User HARUS centang disclaimer beta sebelum scraper aktif. Dipakai
  // sebagai gate di cron + manual scrape.
  isBetaConsented Boolean @default(false)
  // Admin kill switch — set true untuk emergency stop per user (mis. kalau
  // BCA detect anomaly massal). Cron skip kalau true.
  isAdminBlocked  Boolean @default(false)

  lastScrapedAt    DateTime?
  // SUCCESS | AUTH_FAILED | OTP_REQUIRED | BLOCKED | ERROR
  lastScrapeStatus String?
  lastScrapeError  String?   @db.Text

  // Pengaturan match — interval cron, mode auto-confirm, nominal exact match,
  // optional name fuzzy match.
  scrapeIntervalMinutes Int     @default(15)
  autoConfirmEnabled    Boolean @default(true)
  matchByExactAmount    Boolean @default(true)
  matchByCustomerName   Boolean @default(false)

  totalMutationsCaptured Int @default(0)
  totalAutoConfirmed     Int @default(0)
  totalScrapes           Int @default(0)
  totalScrapeFailures    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mutations  BankMutation[]
  scrapeJobs BankScrapeJob[]

  @@index([isActive, isAdminBlocked, lastScrapedAt])
}

// Mutasi rekening individual yang berhasil di-scrape. Hash unik per
// (date+amount+description+type) supaya re-scrape periode yang sama tidak
// duplikat. Match result disimpan di sini juga (matchedOrderId + action).
model BankMutation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  integrationId String
  integration   BankMutationIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  bankCode      String
  accountNumber String

  mutationDate DateTime
  // CR = credit (uang masuk). DB = debit (uang keluar). Hanya CR yang dipakai
  // untuk auto-match order.
  mutationType String
  amount       Float
  description  String   @db.Text
  branch       String?
  balance      Float?

  // SHA256(date|amount|description|type) — dedup key.
  mutationHash String

  // Hasil match. matchedOrderId pakai FK lunak (no @relation) supaya
  // mutation tidak ter-cascade kalau order dihapus.
  matchedOrderId String?
  // AUTO_CONFIRMED | NO_MATCH | MULTIPLE_MATCH | IGNORED | MANUAL_RESOLVED
  matchAction    String?
  matchScore     Float?

  // Raw HTML row buat debug parser kalau kedepannya ada perubahan UI BCA.
  rawHtml String? @db.Text

  createdAt DateTime @default(now())

  @@unique([integrationId, mutationHash])
  @@index([userId, mutationDate(sort: Desc)])
  @@index([matchedOrderId])
  @@index([userId, matchAction])
}

// Audit log per scrape job — debug, monitoring, statistik. Screenshot path
// untuk failure cases supaya bisa inspect halaman BCA yang error.
model BankScrapeJob {
  id            String                  @id @default(cuid())
  integrationId String
  integration   BankMutationIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  status      String // PENDING | RUNNING | SUCCESS | FAILED
  triggeredBy String // CRON | MANUAL | RETRY

  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?   @db.Text

  mutationsFound Int @default(0)
  newMutations   Int @default(0)
  autoConfirmed  Int @default(0)

  // Path file PNG di volume scraper container (./bank-scraper/screenshots/).
  // Hanya diisi untuk failure scenarios.
  screenshotPath String?

  createdAt DateTime @default(now())

  @@index([integrationId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// Follow-Up Order System (2026-05-08, POWER only)
// ─────────────────────────────────────────────────────────────
// Pesan WA otomatis ke customer berdasarkan event order (created/paid/
// shipped/completed/cancelled) atau N-hari setelah event. Gating WA
// session, blacklist, retry, dedup per (order, template) ditangani di
// lib/services/followup-engine.ts dan cron worker.

model FollowUpTemplate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Trigger event:
  //   ORDER_CREATED, PAYMENT_PAID, SHIPPED, COMPLETED, CANCELLED
  //   DAYS_AFTER_ORDER, DAYS_AFTER_PAID, DAYS_AFTER_SHIPPED
  trigger       String
  paymentMethod String? // null = both, COD, TRANSFER

  // Codebase real pisah paymentStatus & deliveryStatus jadi 2 field, jadi
  // gating di sini juga 2 field. Salah satu boleh null = tidak filter.
  applyOnPaymentStatus  String? // PENDING, WAITING_CONFIRMATION, PAID, CANCELLED
  applyOnDeliveryStatus String? // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED

  delayDays Int @default(0) // 0 = immediate, max 30

  name    String
  message String @db.Text

  isActive  Boolean @default(true)
  order     Int     @default(0)
  isDefault Boolean @default(false) // template auto-created saat enable pertama

  scope       String  @default("GLOBAL") // GLOBAL, FORM
  orderFormId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue FollowUpQueue[]

  @@index([userId, trigger, isActive])
}

model FollowUpQueue {
  id         String           @id @default(cuid())
  userId     String
  orderId    String
  order      UserOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  templateId String
  template   FollowUpTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  scheduledAt DateTime
  status      String   @default("PENDING") // PENDING, SENT, FAILED, SKIPPED, CANCELLED

  sentAt       DateTime?
  failedReason String?   @db.Text
  retryCount   Int       @default(0)

  resolvedMessage String @db.Text
  customerPhone   String

  triggerEvent String // event yang trigger queue ini

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, status])
  @@index([orderId, status])
  @@index([userId, status])
}

model FollowUpLog {
  id         String  @id @default(cuid())
  userId     String
  orderId    String
  templateId String?
  queueId    String?

  customerPhone String
  message       String  @db.Text
  status        String // SENT, FAILED
  errorMessage  String? @db.Text

  source String // AUTOMATIC, MANUAL

  sentAt DateTime @default(now())

  @@index([orderId, sentAt(sort: Desc)])
  @@index([userId, sentAt(sort: Desc)])
}

model FollowUpBlacklist {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerPhone String
  reason        String? // "Customer replied STOP", "Manual block", dll
  blockedAt     DateTime @default(now())

  @@unique([userId, customerPhone])
}

// ─────────────────────────────────────────────────────────────────────────
// LMS — Phase 1 MVP (2026-05-09)
// Course/Module/Lesson untuk produk digital + e-course. Course dilink 1:1
// ke Product (Product.courseId @unique). Saat order Product PAID, hook
// auto-enrollment upsert Enrollment untuk customerPhone.
//
// Phase 1 scope: VIDEO_EMBED + TEXT lesson saja (no file upload, no portal
// student, no plan upgrade). Quota soft-hardcoded: 1 course / 5 lesson per
// user FREE — di-replace dgn LmsQuota di Phase 3 (token billing).
// ─────────────────────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonContentType {
  VIDEO_EMBED // YouTube/Vimeo embed URL — Phase 1 default
  TEXT // Markdown / rich text — catatan, transkrip, list link
  FILE // PDF / audio / video upload — Phase 2 (field disiapkan)
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED // admin revoke (refund, fraud)
  EXPIRED // expiresAt lewat (kalau set di Course)
}

model Course {
  id          String       @id @default(cuid())
  userId      String // Penjual (creator) — multi-tenant per user
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Slug per-user unique. Dipakai di URL portal student Phase 2:
  // /belajar/{slug}. Generated dari title saat create, editable.
  slug        String
  title       String
  description String?      @db.Text
  // Cover image — reuse pola Product.imageUrl (path /uploads/lms-covers/...).
  coverUrl    String?
  status      CourseStatus @default(DRAFT)
  // Total durasi semua lesson dalam detik — denormalisasi supaya list course
  // tidak perlu sum lessons. Update saat add/edit/delete lesson.
  totalDurationSec Int @default(0)

  // Reverse 1:1 ke Product. Set via Product.courseId. Optional di sisi
  // Course supaya creator bisa bikin draft course dulu sebelum link product.
  product Product?

  modules     CourseModule[]
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId, status])
}

// Module = chapter / bab. Container untuk grouping Lessons.
model CourseModule {
  id        String  @id @default(cuid())
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  // Urutan tampil di builder + portal student. Manual int supaya gampang
  // re-order via drag (frontend kirim array urut, backend bulk-update).
  sortOrder Int     @default(0)

  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, sortOrder])
}

model Lesson {
  id          String            @id @default(cuid())
  moduleId    String
  module      CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  contentType LessonContentType @default(VIDEO_EMBED)
  // Phase 1: pakai videoEmbedUrl (YT/Vimeo) atau richTextHtml.
  // Phase 2: fileUrl + fileSizeMB diisi saat user upload file.
  videoEmbedUrl String? // YT/Vimeo embed-able URL
  richTextHtml  String? @db.Text
  fileUrl       String? // Phase 2
  fileSizeMB    Int? // Phase 2 — untuk quota storage check
  // Durasi manual (detik) — penjual input atau auto-detect via embed oEmbed
  // di Phase 2. Dipakai untuk progress tracking + total durasi course.
  durationSec   Int     @default(0)
  // Free preview = bisa di-tonton tanpa enrollment. Maks 1-2 per course
  // untuk demo public. Di-enforce di portal Phase 2.
  isFreePreview Boolean @default(false)
  // Drip schedule (Phase 4): null = unlock immediate. Int = unlock setelah
  // N hari sejak enrolledAt. Plan PRO/UNLIMITED only — di-enforce di service
  // saat lesson PATCH. Phase 5 bisa upgrade ke absolute date.
  dripDays      Int?
  sortOrder     Int     @default(0)

  progress LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId, sortOrder])
}

// Enrollment = akses student ke 1 course. Phase 1: di-trigger oleh hook
// on-order-PAID atau admin manual. Phase 2: portal student verify via
// (courseId, studentPhone) match.
model Enrollment {
  id           String           @id @default(cuid())
  courseId     String
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  // Identitas student — phone E.164 (sumber: UserOrder.customerPhone). Email
  // optional (Phase 2 fallback OTP). Name snapshot supaya tampil di admin
  // tanpa lookup contact.
  studentPhone String
  studentName  String?
  studentEmail String?
  // Order yg trigger enrollment (auto-flow). Null = manual oleh admin.
  // SetNull supaya enrollment tidak ikut hilang saat order soft-delete.
  orderId       String?
  order         UserOrder?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // Snapshot invoiceNumber untuk display di admin tanpa join order.
  invoiceNumber String?

  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  // null = lifetime access. Phase 4: kalau course punya periodAccess (mis.
  // 90 hari), auto-set saat enroll.
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokeReason String?

  progress    LessonProgress[]
  // Phase 4 — sertifikat completion. 1:1 (issued sekali per enrollment).
  certificate Certificate?

  // 1 student (phone) tidak bisa enrolled 2x ke course yg sama. Kalau order
  // ulang, upsert ke ACTIVE (bukan create baru).
  @@unique([courseId, studentPhone])
  @@index([courseId, status])
  @@index([studentPhone])
  @@index([orderId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  watchedSec  Int       @default(0)
  completedAt DateTime?
  lastSeenAt  DateTime  @updatedAt

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

// ─────────────────────────────────────────────────────────────────────────
// LMS Phase 2 — Portal student /belajar.
// Student (pembeli course) login pakai WA OTP. Identitas = phone E.164,
// match dgn Enrollment.studentPhone yg di-create otomatis saat order PAID.
// ─────────────────────────────────────────────────────────────────────────

// Session cookie student. Dibuat saat OTP verified, di-pakai sebagai cookie
// httpOnly. Default 30 hari supaya student tidak login terus-menerus.
model StudentSession {
  id           String   @id @default(cuid())
  // Phone E.164 yg login. Banyak session per phone OK (multi-device).
  studentPhone String
  // Random secure token — value cookie. Cek dgn equality.
  sessionToken String   @unique
  // Snapshot info dari Enrollment terbaru — supaya tampilan portal cepat
  // (no join). Update saat verify OTP atau saat enrollment baru.
  studentName  String?
  studentEmail String?
  // User agent / IP buat audit di admin (Phase 4).
  userAgent    String?  @db.Text
  ipAddress    String?
  expiresAt    DateTime
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([studentPhone])
  @@index([expiresAt]) // cron cleanup expired
}

// Magic link login — alternatif ke OTP. Token persistent multi-use TTL 90
// hari. Digunakan saat enrollment auto-flow on-PAID atau resend manual oleh
// student. Tiap klik = create StudentSession baru. Aman karena (a) token
// random 32 byte, (b) auto-revoke saat issue baru utk phone yg sama.
//
// Why: Baileys WA session admin bisa disconnect → OTP gagal sampai. Magic
// link 1x kirim → student simpan/bookmark → bisa re-login tanpa OTP berulang.
model StudentMagicLink {
  id            String    @id @default(cuid())
  studentPhone  String
  // Token random 32-byte hex — value di URL ?t=...
  token         String    @unique
  // Hard expiry. Setelah lewat, klik link dapat error "expired".
  expiresAt     DateTime
  // Pertama kali link di-klik. Null = belum pernah dipakai.
  consumedAt    DateTime?
  // Counter total klik untuk audit. Dipakai juga utk monitoring kalau token
  // bocor (akses dari banyak IP/device beda dlm waktu pendek).
  useCount      Int       @default(0)
  // "WA" | "EMAIL" — channel pengiriman primary saat issue (audit only,
  // bukan enforcement). WA bisa fallback ke EMAIL.
  channel       String
  // "ENROLLMENT" (auto saat order PAID) | "RESEND" (request manual student)
  trigger       String
  // Saat token lebih baru di-issue utk phone yg sama, mark old revoked.
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([studentPhone, revokedAt])
  @@index([expiresAt])
}

// OTP request — temporary record untuk phone yg request OTP. 6-digit kode
// di-hash supaya tidak bocor walau DB dump. Verify dgn timingSafeEqual.
// Throttle: max 3 OTP per phone per 60 menit (di-enforce di service).
model StudentOtp {
  id            String   @id @default(cuid())
  studentPhone  String
  // Hash sha256 dari OTP plaintext (lihat lib/services/lms/student-auth.ts).
  otpHash       String
  // 5 menit sejak issue. Setelah lewat, verify return error.
  expiresAt     DateTime
  // Counter percobaan verify untuk OTP ini. Setelah 5x salah, mark consumed
  // supaya brute force capped.
  attempts      Int      @default(0)
  // Timestamp saat OTP dipakai sukses → mark consumed (tidak bisa di-replay).
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([studentPhone, createdAt(sort: Desc)])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────
// LMS Phase 3 — Plan upgrade via token (mirror flow LP).
// LmsUpgradePackage di-CRUD admin di /admin/lms-packages, harga di-bayar
// pakai saldo token (TOKEN_BALANCE only — tidak ada legacy Tripay/Manual
// path supaya simpler). Quota aktif di LmsQuota di-enforce di service
// course.ts saat create course/lesson.
// ─────────────────────────────────────────────────────────────────────────

enum LmsTier {
  FREE
  BASIC
  PRO
  UNLIMITED
}

model LmsUpgradePackage {
  id          String  @id @default(cuid())
  name        String // "Basic", "Pro", "Unlimited"
  description String?
  tier        LmsTier @unique // FREE row di-seed sekali, tidak di-bayar
  // Limit per plan. -1 = unlimited (di-enforce di service: -1 → bypass).
  maxCourses              Int
  maxLessonsPerCourse     Int
  maxStudentsPerCourse    Int
  maxFileStorageMB        Int     @default(0) // Phase 2 file upload, Phase 4 enforce
  canUseDripSchedule      Boolean @default(false) // Phase 4
  canIssueCertificate     Boolean @default(false) // Phase 4
  // Harga subscription per bulan (Rupiah). Default 0 → FREE (tidak bisa
  // checkout). priceMonthly > 0 wajib supaya muncul di /pricing-lms.
  priceMonthly            Int     @default(0)
  isPopular               Boolean @default(false)
  isActive                Boolean @default(true)
  sortOrder               Int     @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  subscriptions LmsSubscription[]

  @@index([isActive, sortOrder])
}

// Quota LMS per-user (penjual). 1:1, di-upsert saat:
//   - Bayar plan (LmsSubscription ACTIVE)
//   - Subscription EXPIRED → downgrade ke FREE
//   - Manual admin adjust
// Default FREE row di-create lazily saat user pertama kali butuh quota.
model LmsQuota {
  id                    String  @id @default(cuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                  LmsTier @default(FREE)
  maxCourses            Int     @default(1)
  maxLessonsPerCourse   Int     @default(5)
  maxStudentsPerCourse  Int     @default(50)
  maxFileStorageMB      Int     @default(0)
  canUseDripSchedule    Boolean @default(false)
  canIssueCertificate   Boolean @default(false)
  updatedAt             DateTime @updatedAt
}

model LmsSubscription {
  id              String  @id @default(cuid())
  userId          String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lmsPackageId    String
  lmsPackage      LmsUpgradePackage @relation(fields: [lmsPackageId], references: [id])
  durationMonths  Int     // 1 | 3 | 6 | 12 (mirror DURATION_DISCOUNTS LP)
  startDate       DateTime
  endDate         DateTime
  // ACTIVE | EXPIRED | CANCELLED
  status          String  @default("ACTIVE")
  // Pricing snapshot (IDR) supaya audit historis akurat walau plan
  // priceMonthly berubah.
  priceBase       Int
  discountPct     Int     @default(0)
  priceFinal      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices LmsSubscriptionInvoice[]

  @@index([userId, status])
  @@index([endDate]) // cron expire scan
}

model LmsSubscriptionInvoice {
  id              String  @id @default(cuid())
  subscriptionId  String
  subscription    LmsSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceNumber   String  @unique
  amount          Int     // IDR
  // Token equivalent yg dipotong (snapshot pricePerToken aktif saat checkout).
  tokenAmount     Int
  description     String  @db.Text
  // PAID — Phase 3 tidak ada PENDING karena atomic deduct token.
  status          String  @default("PAID")
  paidAt          DateTime
  createdAt       DateTime @default(now())
}

// LMS Phase 4 — Sertifikat completion. Di-issue saat student selesai
// semua lesson di course (filter via LessonProgress.completedAt).
// Plan canIssueCertificate gating di-enforce di service (BASIC: false,
// PRO/UNLIMITED: true).
//
// Snapshot studentName + courseTitle + courseSlug supaya sertifikat
// tetap valid display walau course title diubah atau di-archive nanti.
model Certificate {
  id            String  @id @default(cuid())
  // Number unik public-shareable (mis. "HULAO-LMS-2026-XXXXXX"). Dipakai
  // di URL verify /belajar/certificate/{number}. Indexed unique.
  number        String  @unique
  enrollmentId  String  @unique
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  // Snapshot supaya rendering certificate page tidak butuh join saat
  // course title berubah / archive di kemudian hari.
  studentName   String
  studentPhone  String
  courseTitle   String
  courseSlug    String
  // Snapshot creator (penjual) name + ID — untuk credit di certificate.
  issuerUserId  String
  issuerName    String
  issuedAt      DateTime @default(now())

  @@index([studentPhone])
  @@index([issuerUserId])
}

// ─────────────────────────────────────────────────────────────────────────
// CONTENT STUDIO + IDEA GENERATOR — Phase 1
//
// Idea Generator = entry point setelah user save LP. AI hasilkan 15 ide via
// 3 metode (HOOK framework / PAIN-point / PERSONA POV). User pick & choose
// → ContentBrief → Content Studio generate full body per channel.
//
// Free preview tactic: 3 ide pertama (HOOK_1, PAIN_1, PERSONA_1) tampil
// gratis tanpa deduct token. 12 sisanya gated, klik "Buka semua" → top up
// kalau saldo nol, lalu deduct atomic.
//
// Pricing admin-controllable via AiFeatureConfig — sumber kebenaran pricing
// untuk SEMUA AI feature (Content Studio sekarang, future LP Lab migration).
// Profitability tracking via AiGenerationLog yg jadi source untuk cron
// profitability-check.
// ─────────────────────────────────────────────────────────────────────────

// Per-feature pricing config admin-tunable. featureKey unique → semua AI
// service fetch via getFeatureConfig(key) dengan cache. Ganti rate / margin
// di admin UI = effect langsung tanpa deploy.
model AiFeatureConfig {
  id                String   @id @default(cuid())
  featureKey        String   @unique // 'CONTENT_IDEA' | 'CONTENT_GENERATE' | 'LP_OPTIMIZE' | future
  displayName       String   // tampilan admin UI: "Idea Generator", "Content Generation"
  modelName         String   // 'claude-haiku-4-5' | 'claude-sonnet-4-6' (snapshot ke log)
  // Provider rate (USD per 1M token). Admin update saat Anthropic naik harga.
  inputPricePer1M   Float
  outputPricePer1M  Float
  // Margin multiplier — 1.3 = +30% margin platform.
  platformMargin    Float    @default(1.3)
  // Floor minimum token charge per call (anti-mikro-call).
  floorTokens       Int      @default(100)
  // Cap maksimum token charge per call (sanity guard kalau outlier cost).
  capTokens         Int      @default(50000)
  isActive          Boolean  @default(true)
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Tabel log umum untuk semua AI feature generation. Source of truth untuk
// /admin/profitability + cron profitability-check (extend dari Message-only).
model AiGenerationLog {
  id              String   @id @default(cuid())
  featureKey      String   // FK logical ke AiFeatureConfig
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Subject ref — bebas: 'LP', 'CONTENT_IDEA_BATCH', 'CONTENT_PIECE'
  subjectType     String?
  subjectId       String?
  // Real Anthropic usage — input/output tokens sesuai SDK response.
  inputTokens     Int
  outputTokens   Int
  // Cost provider IDR (snapshot kurs saat call).
  apiCostUsd      Float
  apiCostRp       Float
  // Token platform di-deduct dari user.
  tokensCharged   Int
  // Pendapatan platform (IDR) = tokensCharged × pricePerToken (snapshot kurs).
  revenueRp       Float
  // Profit (IDR) = revenueRp - apiCostRp. Bisa negatif (loss).
  profitRp        Float
  // Margin % = (profit / revenue) × 100. Cron pakai untuk MARGIN_LOW alert.
  marginPct       Float
  modelName       String
  // Snapshot full config saat call — audit trail kalau pricing berubah.
  pricingSnapshot Json
  // Status: 'OK' | 'FAILED' (AI error tapi belum di-charge) | 'INSUFFICIENT_BALANCE'
  status          String   @default("OK")
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([featureKey, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// Idea hasil Idea Generator. User pick & choose dari 15 ide → promote jadi
// ContentPiece. promotedToPieceId nullable — null = belum di-generate konten
// full-nya, hanya ide di library.
model ContentIdea {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Source LP — null kalau brief manual.
  lpId              String?
  lp                LandingPage? @relation(fields: [lpId], references: [id], onDelete: SetNull)
  // 'HOOK' | 'PAIN' | 'PERSONA' — dari metode mana ide ini dihasilkan.
  method            String
  // Hook tagline pembuka konten — 1 baris pendek.
  hook              String    @db.Text
  // Sudut pendekatan — 1-2 kalimat, konteks utk AI saat generate konten full.
  angle             String    @db.Text
  // Channel yg cocok untuk ide ini (multi). Mis. ['IG_REELS', 'TIKTOK'].
  channelFit        String[]
  // Format konten yg cocok ('VIDEO_SCRIPT' | 'CAROUSEL' | 'SINGLE_IMAGE' | 'TEXT_POST').
  format            String
  // Reasoning AI 1-2 kalimat kenapa ini bekerja.
  whyItWorks        String    @db.Text
  // Prediksi virality 1-5 (best-effort AI estimate).
  predictedVirality Int       @default(3)
  // 'TOFU' | 'MOFU' | 'BOFU'
  funnelStage       String
  // Estimasi token cost prediksi kalau jadi konten full (utk display "Bikin ini Rp X").
  estimatedTokens   Int       @default(800)
  // Free preview gate — true = ide ini visible gratis. False = blur kalau saldo nol.
  isFreePreview     Boolean   @default(false)
  // Promote ke ContentPiece kalau user pilih.
  promotedToPieceId String?   @unique
  promotedToPiece   ContentPiece? @relation(fields: [promotedToPieceId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([lpId, createdAt])
}

// Brief = batch generation request. Boleh dari LP atau brief manual.
// selectedIdeaIds di-snapshot ke ContentPiece.sourceIdeaId saat generate.
model ContentBrief {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lpId            String?
  lp              LandingPage? @relation(fields: [lpId], references: [id], onDelete: SetNull)
  // Manual brief fields — dipakai kalau lpId null.
  manualTitle     String?
  manualAudience  String?   @db.Text
  manualOffer     String?   @db.Text
  // Tone preset: 'CASUAL' | 'EDUKATIF' | 'AGGRESSIVE_OFFER' | 'STORYTELLING'
  tone            String    @default("CASUAL")
  // Target funnel mix — Json {tofu: 4, mofu: 3, bofu: 3} default.
  funnelMix       Json
  // Status: 'DRAFT' (sedang pilih ide) | 'GENERATING' (AI run) | 'COMPLETED' | 'FAILED'
  status          String    @default("DRAFT")
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pieces          ContentPiece[]

  @@index([userId, createdAt])
  @@index([lpId, createdAt])
}

// ContentPiece = 1 unit konten full (sudah ada body). Channel-aware.
model ContentPiece {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  briefId         String?
  brief           ContentBrief? @relation(fields: [briefId], references: [id], onDelete: SetNull)
  // Source idea kalau di-promote dari Idea Generator.
  sourceIdeaId    String?   @unique
  sourceIdea      ContentIdea?
  // Channel: 'WA_STATUS' | 'IG_STORY' | 'IG_POST' | 'IG_CAROUSEL' | 'IG_REELS' | 'TIKTOK' | 'META_ADS' | 'TIKTOK_ADS'
  channel         String
  // Funnel: 'TOFU' | 'MOFU' | 'BOFU'
  funnelStage     String
  // Format detail: 'TEXT' | 'CAROUSEL' | 'VIDEO_SCRIPT' | 'SINGLE_IMAGE' | 'ADS_IMAGE' | 'ADS_VIDEO' | 'ADS_CAROUSEL'
  format          String
  // Title untuk display di library.
  title           String
  // Body lengkap — flexible JSON sesuai channel:
  //   WA_STATUS / IG_STORY / IG_POST: { caption, hook, cta, hashtags[] }
  //   IG_CAROUSEL: { slides: [{headline, body}], caption, cta, hashtags[] }
  //   IG_REELS / TIKTOK: { hook, scenes: [{seconds, narration, visual, broll}], caption, cta, soundSuggest }
  //   META_ADS/TIKTOK_ADS: { primaryTexts[], headlines[], description, ctaButton, visualBrief, storyboard? }
  bodyJson        Json
  // Status: 'DRAFT' | 'READY' | 'POSTED' | 'ARCHIVED'
  status          String    @default("DRAFT")
  // Audit token spend untuk piece ini.
  tokensCharged   Int       @default(0)
  // Phase 3 — kalender konten. User schedule manual; tidak ada auto-publish
  // (cuma reminder/planning view). Null = belum dijadwalkan.
  scheduledFor    DateTime?
  postedAt        DateTime?
  // Phase 5 — performance loop. User input metric manual setelah POSTED.
  // Field optional; null = belum di-record. metricUpdatedAt jadi anchor
  // untuk dashboard insights "konten yg punya data".
  reach           Int?
  impressions     Int?
  saves           Int?
  shares          Int?
  comments        Int?
  dms             Int?
  linkClicks      Int?
  metricUpdatedAt DateTime?
  // Phase 6 — Ads creative discriminator
  // 'ORGANIC' (default) | 'ADS'. Field-level filter di Library.
  pieceType       String    @default("ORGANIC")
  // 'META_ADS' | 'TIKTOK_ADS' | null. Null untuk organic.
  adsPlatform     String?
  // 'IMAGE' | 'VIDEO' | 'CAROUSEL' | null. Null untuk organic.
  adsFormat       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  slides          ContentSlide[]
  variants        AdVariant[]

  @@index([userId, status, createdAt])
  @@index([briefId, createdAt])
  @@index([channel, status])
  @@index([userId, scheduledFor])
  @@index([userId, pieceType, status])
}

// Phase 6 — variant headline/primary/description/CTA per ad piece. User
// boleh A/B test multi variant per piece. Performance metric per variant
// di-record manual (impressions/clicks/CTR/conversions/spendRp).
model AdVariant {
  id              String    @id @default(cuid())
  pieceId         String
  piece           ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  // 'HEADLINE' | 'PRIMARY_TEXT' | 'DESCRIPTION' | 'CTA'
  variantType     String
  value           String    @db.Text
  // Order untuk display 0..N (A, B, C, ...)
  order           Int       @default(0)
  // Performance per variant — user input manual setelah jalan ads.
  impressions     Int?
  clicks          Int?
  ctr             Float?
  conversions     Int?
  spendRp         Int?
  metricUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pieceId, variantType, order])
}

// Stub Phase 2 — saat visual generator implement. Phase 1 sudah create row
// supaya backfill bisa dilakukan tanpa migrasi data ulang.
model ContentSlide {
  id          String   @id @default(cuid())
  pieceId     String
  piece       ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  slideIndex  Int
  headline    String
  body        String   @db.Text
  // templateId & imageUrl di-isi Phase 2 (visual generator).
  templateId  String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pieceId, slideIndex])
  @@index([pieceId])
}
