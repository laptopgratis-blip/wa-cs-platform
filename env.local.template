# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Pakai Supabase (gratis): https://supabase.com
# Setelah buat project, copy connection string dari Settings > Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────
# Generate secret: jalankan perintah ini di terminal:
# openssl rand -base64 32
NEXTAUTH_SECRET="isi-dengan-random-string-panjang"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (opsional untuk login dengan Google)
# Buat di: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────
# AI MODELS
# ─────────────────────────────────────────
# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (opsional)
# OPENAI_API_KEY="sk-..."

# Google Gemini (opsional)
# GOOGLE_AI_API_KEY=""

# ─────────────────────────────────────────
# PAYMENT — TRIPAY
# ─────────────────────────────────────────
# Buat akun di: https://tripay.co.id
# Gunakan Sandbox dulu untuk testing — endpoint: https://tripay.co.id/api-sandbox/
# Set TRIPAY_IS_PRODUCTION=true setelah verifikasi merchant production.
TRIPAY_API_KEY=""
TRIPAY_PRIVATE_KEY=""
TRIPAY_MERCHANT_CODE=""
TRIPAY_IS_PRODUCTION="false"
# Method default saat create transaksi (mis. QRIS, BRIVA, BCAVA, OVO).
# Bisa di-override per request dari frontend kalau perlu.
TRIPAY_DEFAULT_METHOD="QRIS"

# ─────────────────────────────────────────
# WA SERVICE
# ─────────────────────────────────────────
# URL service WA yang jalan di port 3001
WA_SERVICE_URL="http://localhost:3001"
WA_SERVICE_SECRET="secret-untuk-komunikasi-internal"
NEXT_PUBLIC_WA_SERVICE_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="WA CS Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin pertama (email yang otomatis jadi admin saat register)
ADMIN_EMAIL="arli@email.com"

# ─────────────────────────────────────────
# EMAIL (untuk reset password, notifikasi)
# ─────────────────────────────────────────
# Untuk dev pakai Mailtrap (gratis): https://mailtrap.io
# Buat inbox, copy SMTP credentials di tab "Show Credentials"
EMAIL_HOST="sandbox.smtp.mailtrap.io"
EMAIL_PORT="2525"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="WA CS Platform <no-reply@wa-cs.local>"
